# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB — replace with your Atlas connection string
MONGODB_URI=mongodb://localhost:27017/eternally

# Paymob — replace with your credentials from https://accept.paymob.com/portal2/en/login
PAYMOB_API_KEY=replace_me
PAYMOB_INTEGRATION_ID=replace_me
PAYMOB_IFRAME_ID=replace_me
PAYMOB_HMAC_SECRET=replace_me

# Pricing in EGP (whole pounds, e.g. 4900 = 4,900 EGP)
PRICE_EGP=4900

# Cloudinary — replace with your credentials from https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=replace_me@gmail.com
SMTP_PASS=replace_me
EMAIL_FROM="Eternally" <noreply@eternally.co>
