# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
SERVER_URL=http://localhost:4000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/veloura?retryWrites=true&w=majority

# PayPal Sandbox - testing only, no real payments
# Switch PAYPAL_ENVIRONMENT to "live" and replace credentials with live values for production.
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=replace_me_paypal_client_id
PAYPAL_CLIENT_SECRET=replace_me_paypal_client_secret
PAYPAL_WEBHOOK_ID=replace_me_paypal_webhook_id

# Pricing
# PayPal checkout currency must stay USD because PayPal REST Checkout does not support EGP as a transaction currency.
# Legacy fallback only. Actual checkout amounts come from server/data/pricingTiers.js.
PRICE_USD=69.00
PRICE_CURRENCY=USD
# Used to convert fixed Egyptian EGP prices into the USD amount charged by PayPal.
USD_TO_EGP_RATE=53.00
# Optional: set this when your hosting provider exposes the visitor's ISO country
# through a different trusted header (for example: x-your-platform-country).
TRUSTED_COUNTRY_HEADER=

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Brevo Transactional API)
BREVO_API_KEY=xkeysib-your-brevo-api-key
BREVO_SENDER_EMAIL=veloura.invitations@gmail.com
BREVO_SENDER_NAME=Veloura
